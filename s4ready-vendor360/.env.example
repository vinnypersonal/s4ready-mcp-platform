# ─────────────────────────────────────────────────────────
# s4ready Vendor 360 — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────

# ── Deployment mode ───────────────────────────────────────
# standalone | btp | hybrid
DEPLOY_MODE=standalone

# ── Server ───────────────────────────────────────────────
PORT=8080
NODE_ENV=development
LOG_LEVEL=info

# ── SAP Connection ────────────────────────────────────────
# SAP_MODE=mock         → use built-in mock data (default, no SAP needed)
# SAP_MODE=direct       → call your real SAP system
# SAP_MODE=btp          → use BTP Destination Service (requires DEPLOY_MODE=btp)
SAP_MODE=mock

# Direct connection (SAP_MODE=direct only)
SAP_BASE_URL=https://your-s4.example.com
SAP_USERNAME=your_user
SAP_PASSWORD=your_password
SAP_CLIENT=100
SAP_INSECURE_TLS=false   # set true only for dev with self-signed certs

# ── Database (standalone mode) ────────────────────────────
# Use DATABASE_URL OR individual DB_* vars (DATABASE_URL takes precedence)
DATABASE_URL=postgresql://s4ready:s4ready@localhost:5432/s4ready

# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=s4ready
# DB_PASSWORD=s4ready
# DB_NAME=s4ready

# ── AI (standalone mode) ──────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
AI_MODEL=claude-sonnet-4-6

# ── Auth (standalone mode) ────────────────────────────────
# Option A: JWKS (production) — your OIDC provider
# OIDC_ISSUER=https://your-idp.example.com
# OIDC_JWKS_URI=https://your-idp.example.com/.well-known/jwks.json
# OIDC_AUDIENCE=s4ready-vendor360

# Option B: Shared secret (dev only — HS256)
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_TENANT_CLAIM=tenant_id

# ── Multi-tenancy ─────────────────────────────────────────
# In dev (single-tenant mode), all requests resolve to this tenant
DEFAULT_TENANT_ID=default
# Skip auth entirely in local dev — set to false in any shared environment
SKIP_AUTH=true

# ── BTP mode (when DEPLOY_MODE=btp) ──────────────────────
# These are injected automatically by CF via VCAP_SERVICES.
# You only need them if running outside CF (rare).
# VCAP_SERVICES={"xsuaa":[...],"hana":[...],"aicore":[...],...}
